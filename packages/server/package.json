{
  "name": "@belote/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Authoritative server: rooms, session orchestration, ws transport",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "dev": "tsx watch src/bin/serve.ts",
    "start": "tsx src/bin/serve.ts"
  },
  "dependencies": {
    "@belote/core": "workspace:*",
    "@belote/app": "workspace:*",
    "@belote/protocol": "workspace:*",
    "fastify": "^5.2.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2"
  }
}
